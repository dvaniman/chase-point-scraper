# Chase login: credentials by group (see config.yaml account_credentials).
# Never commit .env. Copy this file to .env and fill in the values after =.

# Fallback (if an account has no entry in config account_credentials):
CHASE_USERNAME=
CHASE_PASSWORD=

# Freedom-dsv + Sapphire Pref (same credentials)
CHASE_USER_FREEDOM_DSV=
CHASE_PASSWORD_FREEDOM_DSV=

# Ink Pref, Ink Cash, Ink Unlt (same credentials)
CHASE_USER_INK_GROUP=
CHASE_PASSWORD_INK_GROUP=

# Chase SR + Freedom-kev (same credentials)
CHASE_USER_CHASE_SR=
CHASE_PASSWORD_CHASE_SR=

# Optional: set to "1" to run browser visible (required for 2FA — complete code in browser when prompted)
CHASE_HEADED=1
